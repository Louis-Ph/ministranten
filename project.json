{
  "name": "web",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": ".",
  "sourceRoot": ".",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Web app - no build step required (static files)'"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx http-server -p 8080 -c-1 -s ."
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx http-server -p 8080 -c-1 -s ."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No lint configured'"
      }
    }
  },
  "tags": ["type:app", "scope:minis-wettstetten"]
}
