# Vercel runtime secrets. Copy to .env.local for local `vercel dev`.
# Never commit .env.local.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_BASE_URL=http://localhost:3000

# Free default: Google, GitHub and Microsoft. Add apple only when your
# organization has an Apple Developer Program fee waiver or accepts the paid fee.
APP_OAUTH_PROVIDERS=google,github,azure

# Optional hard gate for OAuth/password users. Comma-separated domains.
APP_ALLOWED_EMAIL_DOMAINS=
