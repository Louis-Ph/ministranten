{
  "name": "api",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "api",
  "sourceRoot": "api",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "outputPath": "dist/api",
        "main": "index.ts",
        "tsConfig": "tsconfig.json",
        "assets": []
      },
      "outputs": ["{options.outputPath}"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vercel dev --force",
        "cwd": ".."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p tsconfig.json --noEmit",
        "cwd": "api"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No lint configured'"
      }
    }
  },
  "tags": ["type:lib", "scope:api"]
}
