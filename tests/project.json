{
  "name": "test",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "tests",
  "sourceRoot": "tests",
  "targets": {
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}/.."
      },
      "inputs": ["default", "^production"],
      "cache": true,
      "outputs": []
    },
    "test:e2e": {
      "executor": "@nx/playwright:playwright",
      "dependsOn": ["^build"],
      "options": {
        "configPath": "../playwright.config.js"
      },
      "outputs": ["{workspaceRoot}/playwright-report"]
    }
  },
  "tags": ["scope:shared", "type:testing"]
}
