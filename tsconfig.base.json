{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"],
    "strict": false,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@minis/api/*": ["api/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [],
  "exclude": ["node_modules", "dist"]
}
