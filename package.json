{
  "name": "minis-wettstetten",
  "private": true,
  "version": "1.0.0",
  "description": "Progressive Web App für die Ministrantinnen und Ministranten der Pfarrei Wettstetten mit Vercel API Routes und Supabase Postgres/Auth.",
  "keywords": [
    "pwa",
    "vanilla-js",
    "vercel",
    "supabase",
    "ministranten",
    "dienstplan",
    "wcag",
    "accessibility",
    "single-file"
  ],
  "author": "Minis Wettstetten",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Louis-Ph/ministranten.git"
  },
  "bugs": {
    "url": "https://github.com/Louis-Ph/ministranten/issues"
  },
  "homepage": "https://github.com/Louis-Ph/ministranten#readme",
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "http-server -p 8080 -c-1 -s .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
